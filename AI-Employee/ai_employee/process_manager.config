# ═══════════════════════════════════════════════════════════════════════════
#  AI Employee — Cloud Process Manager Configuration (Platinum Tier)
#
#  Defines all processes that run on the Cloud VM.
#  Compatible with: supervisord, systemd (generator below), and the
#  built-in process_manager.py runner.
#
#  Process groups:
#    [watchers]   — 6 always-on service watchers (cloud_watchers.py)
#    [mcp]        — 4 MCP tool servers (FastMCP over HTTP)
#    [infra]      — Odoo, PostgreSQL, Nginx
#    [sync]       — Git sync agent (git_sync.sh)
#    [health]     — Health endpoint (built into cloud_watchers.py)
#
#  Usage:
#    supervisord -c ai_employee/process_manager.config
#
#    — or generate systemd units —
#    python -m ai_employee.process_manager --generate-systemd
# ═══════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────
#  SUPERVISORD GLOBAL
# ─────────────────────────────────────────────────────────────────────────

[supervisord]
nodaemon        = true
logfile         = /opt/ai-employee/ai_employee/logs/supervisord.log
logfile_maxbytes= 10MB
logfile_backups = 3
loglevel        = info
pidfile         = /var/run/ai-employee/supervisord.pid
childlogdir     = /opt/ai-employee/ai_employee/logs/

[unix_http_server]
file = /var/run/ai-employee/supervisor.sock

[supervisorctl]
serverurl = unix:///var/run/ai-employee/supervisor.sock

[rpcinterface:supervisor]
supervisor.rpcinterface_factory = supervisor.rpcinterface:make_main_rpcinterface


# ─────────────────────────────────────────────────────────────────────────
#  GROUP: watchers — All 6 cloud watchers in a single process
# ─────────────────────────────────────────────────────────────────────────
#
#  Runs cloud_watchers.py which spawns 6 internal threads:
#    Gmail (2m), WhatsApp (1m), LinkedIn (5m), Twitter (3m),
#    Instagram (5m), Odoo (10m)
#
#  The process also exposes :9090/health for monitoring.
#

[program:cloud-watchers]
command         = /opt/ai-employee/venv/bin/python -m ai_employee.cloud_watchers --all --health-port 9090
directory       = /opt/ai-employee
environment     =
    SYNC_ROLE="cloud",
    WATCHER_GMAIL_INTERVAL="120",
    WATCHER_WHATSAPP_INTERVAL="60",
    WATCHER_LINKEDIN_INTERVAL="300",
    WATCHER_TWITTER_INTERVAL="180",
    WATCHER_INSTAGRAM_INTERVAL="300",
    WATCHER_ODOO_INTERVAL="600"
user            = ai-employee
autostart       = true
autorestart     = true
startsecs       = 5
startretries    = 5
stopwaitsecs    = 15
stopsignal      = TERM
redirect_stderr = true
stdout_logfile  = /opt/ai-employee/ai_employee/logs/cloud_watchers.log
stdout_logfile_maxbytes = 10MB
stdout_logfile_backups  = 3


# ─────────────────────────────────────────────────────────────────────────
#  GROUP: mcp — MCP Tool Servers (one process each)
# ─────────────────────────────────────────────────────────────────────────
#
#  Each MCP server runs as a FastMCP HTTP adapter on its own port.
#  Nginx proxies external traffic to these ports.
#

[program:mcp-communication]
command         = /opt/ai-employee/venv/bin/python -m ai_employee.integrations.mcp_communication_server
directory       = /opt/ai-employee
user            = ai-employee
autostart       = true
autorestart     = true
startsecs       = 3
startretries    = 3
stopwaitsecs    = 10
stopsignal      = TERM
redirect_stderr = true
stdout_logfile  = /opt/ai-employee/ai_employee/logs/mcp_communication.log
stdout_logfile_maxbytes = 5MB
stdout_logfile_backups  = 2
# Port: 9001 (configured in the MCP server module)

[program:mcp-meta-social]
command         = /opt/ai-employee/venv/bin/python -m ai_employee.integrations.mcp_meta_server
directory       = /opt/ai-employee
user            = ai-employee
autostart       = true
autorestart     = true
startsecs       = 3
startretries    = 3
stopwaitsecs    = 10
stopsignal      = TERM
redirect_stderr = true
stdout_logfile  = /opt/ai-employee/ai_employee/logs/mcp_meta.log
stdout_logfile_maxbytes = 5MB
stdout_logfile_backups  = 2
# Port: 9002

[program:mcp-twitter-social]
command         = /opt/ai-employee/venv/bin/python -m ai_employee.integrations.mcp_twitter_server
directory       = /opt/ai-employee
user            = ai-employee
autostart       = true
autorestart     = true
startsecs       = 3
startretries    = 3
stopwaitsecs    = 10
stopsignal      = TERM
redirect_stderr = true
stdout_logfile  = /opt/ai-employee/ai_employee/logs/mcp_twitter.log
stdout_logfile_maxbytes = 5MB
stdout_logfile_backups  = 2
# Port: 9003

[program:mcp-odoo-accounting]
command         = /opt/ai-employee/venv/bin/python -m ai_employee.integrations.odoo_mcp_server
directory       = /opt/ai-employee
user            = ai-employee
autostart       = true
autorestart     = true
startsecs       = 3
startretries    = 3
stopwaitsecs    = 10
stopsignal      = TERM
redirect_stderr = true
stdout_logfile  = /opt/ai-employee/ai_employee/logs/mcp_odoo.log
stdout_logfile_maxbytes = 5MB
stdout_logfile_backups  = 2
# Port: 9004


[group:mcp-servers]
programs = mcp-communication,mcp-meta-social,mcp-twitter-social,mcp-odoo-accounting
priority = 10


# ─────────────────────────────────────────────────────────────────────────
#  GROUP: sync — Git vault sync agent
# ─────────────────────────────────────────────────────────────────────────
#
#  Runs git_sync.sh in cloud mode: pull → push every 5 minutes.
#  Handles conflict resolution via conflict_resolver.py.
#

[program:git-sync]
command         = /usr/bin/bash /opt/ai-employee/scripts/git_sync.sh --cloud
directory       = /opt/ai-employee
environment     =
    SYNC_ROLE="cloud",
    SYNC_INTERVAL="300",
    SYNC_REMOTE="origin",
    SYNC_BRANCH="main",
    PROJECT_ROOT="/opt/ai-employee"
user            = ai-employee
autostart       = true
autorestart     = true
startsecs       = 5
startretries    = 3
stopwaitsecs    = 30
stopsignal      = TERM
redirect_stderr = true
stdout_logfile  = /opt/ai-employee/ai_employee/logs/git_sync.log
stdout_logfile_maxbytes = 10MB
stdout_logfile_backups  = 3


# ─────────────────────────────────────────────────────────────────────────
#  GROUP: infra — Infrastructure services
# ─────────────────────────────────────────────────────────────────────────
#
#  Odoo and PostgreSQL are typically managed by systemd directly,
#  but included here for completeness if running in Docker or
#  a supervisor-only environment.
#
#  NOTE: If Odoo/PostgreSQL are already managed by systemd,
#  set autostart=false and manage them separately.
#

[program:odoo]
command         = /opt/odoo/venv/bin/python /opt/odoo/odoo-bin -c /etc/odoo/odoo.conf
directory       = /opt/odoo
user            = odoo
autostart       = false
autorestart     = true
startsecs       = 10
startretries    = 3
stopwaitsecs    = 30
stopsignal      = TERM
redirect_stderr = true
stdout_logfile  = /var/log/odoo/odoo.log
stdout_logfile_maxbytes = 50MB
stdout_logfile_backups  = 5
# Port: 8069

[program:nginx]
command         = /usr/sbin/nginx -g "daemon off;"
user            = root
autostart       = false
autorestart     = true
startsecs       = 2
startretries    = 3
stopsignal      = QUIT
redirect_stderr = true
stdout_logfile  = /var/log/nginx/supervisor.log
stdout_logfile_maxbytes = 10MB
# Port: 443

[group:infra]
programs = odoo,nginx
priority = 5


# ─────────────────────────────────────────────────────────────────────────
#  PROCESS DEPENDENCY ORDER (via priority)
# ─────────────────────────────────────────────────────────────────────────
#
#  Priority (lower = starts first):
#    5   infra        — Odoo, Nginx (if managed here)
#    10  mcp-servers  — MCP tool servers
#    20  git-sync     — Vault sync agent
#    30  watchers     — Cloud watchers (needs agents which need MCP)
#
#  This ensures infrastructure is ready before watchers start polling.
#


# ═══════════════════════════════════════════════════════════════════════════
#  SYSTEMD UNIT TEMPLATES
# ═══════════════════════════════════════════════════════════════════════════
#
#  If you prefer systemd over supervisord, use these unit templates.
#  Save each to /etc/systemd/system/ and run:
#    systemctl daemon-reload
#    systemctl enable --now ai-employee-watchers ai-employee-sync
#
#  ── ai-employee-watchers.service ─────────────────────────────────────
#  [Unit]
#  Description=AI Employee Cloud Watchers
#  After=network.target postgresql.service odoo.service
#  Wants=ai-employee-sync.service
#
#  [Service]
#  Type=simple
#  User=ai-employee
#  Group=ai-employee
#  WorkingDirectory=/opt/ai-employee
#  EnvironmentFile=/etc/ai-employee/.env
#  Environment=SYNC_ROLE=cloud
#  Environment=WATCHER_GMAIL_INTERVAL=120
#  Environment=WATCHER_WHATSAPP_INTERVAL=60
#  Environment=WATCHER_LINKEDIN_INTERVAL=300
#  Environment=WATCHER_TWITTER_INTERVAL=180
#  Environment=WATCHER_INSTAGRAM_INTERVAL=300
#  Environment=WATCHER_ODOO_INTERVAL=600
#  ExecStart=/opt/ai-employee/venv/bin/python -m ai_employee.cloud_watchers --all --health-port 9090
#  Restart=always
#  RestartSec=10
#  StandardOutput=append:/opt/ai-employee/ai_employee/logs/cloud_watchers.log
#  StandardError=append:/opt/ai-employee/ai_employee/logs/cloud_watchers.log
#
#  [Install]
#  WantedBy=multi-user.target
#
#  ── ai-employee-sync.service ─────────────────────────────────────────
#  [Unit]
#  Description=AI Employee Git Vault Sync
#  After=network.target
#
#  [Service]
#  Type=simple
#  User=ai-employee
#  Group=ai-employee
#  WorkingDirectory=/opt/ai-employee
#  EnvironmentFile=/etc/ai-employee/.env
#  Environment=SYNC_ROLE=cloud
#  Environment=SYNC_INTERVAL=300
#  ExecStart=/usr/bin/bash /opt/ai-employee/scripts/git_sync.sh --cloud
#  Restart=always
#  RestartSec=10
#  StandardOutput=append:/opt/ai-employee/ai_employee/logs/git_sync.log
#  StandardError=append:/opt/ai-employee/ai_employee/logs/git_sync.log
#
#  [Install]
#  WantedBy=multi-user.target
#
#  ── ai-employee-mcp@.service (template) ──────────────────────────────
#  [Unit]
#  Description=AI Employee MCP Server - %i
#  After=network.target
#
#  [Service]
#  Type=simple
#  User=ai-employee
#  Group=ai-employee
#  WorkingDirectory=/opt/ai-employee
#  EnvironmentFile=/etc/ai-employee/.env
#  ExecStart=/opt/ai-employee/venv/bin/python -m ai_employee.integrations.%i
#  Restart=always
#  RestartSec=5
#
#  [Install]
#  WantedBy=multi-user.target
#
#  Enable with:
#    systemctl enable --now ai-employee-mcp@mcp_communication_server
#    systemctl enable --now ai-employee-mcp@mcp_meta_server
#    systemctl enable --now ai-employee-mcp@mcp_twitter_server
#    systemctl enable --now ai-employee-mcp@odoo_mcp_server
#
# ═══════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────
#  ENVIRONMENT VARIABLE REFERENCE
# ─────────────────────────────────────────────────────────────────────────
#
#  All variables are loaded from /etc/ai-employee/.env on the Cloud VM.
#
#  ── Core ──
#  ANTHROPIC_API_KEY          Claude API key
#  SYNC_ROLE                  "cloud" (always for cloud VM)
#  PROJECT_ROOT               /opt/ai-employee
#
#  ── Gmail ──
#  EMAIL_ADDRESS              Gmail address
#  EMAIL_PASSWORD             App password
#  GMAIL_CREDENTIALS_FILE     Path to credentials.json
#  GMAIL_TOKEN_FILE           Path to token.json
#
#  ── WhatsApp ──
#  WHATSAPP_TOKEN             Meta WhatsApp Business API token
#  WHATSAPP_PHONE_NUMBER_ID   WhatsApp Business phone number ID
#
#  ── LinkedIn ──
#  LINKEDIN_EMAIL             LinkedIn login email
#  LINKEDIN_PASSWORD          LinkedIn login password
#
#  ── Twitter ──
#  TWITTER_BEARER_TOKEN       Twitter API v2 bearer token
#  TWITTER_API_KEY            Twitter consumer key
#  TWITTER_API_SECRET         Twitter consumer secret
#  TWITTER_ACCESS_TOKEN       Twitter OAuth access token
#  TWITTER_ACCESS_TOKEN_SECRET Twitter OAuth access secret
#
#  ── Instagram / Meta ──
#  META_ACCESS_TOKEN          Long-lived page access token
#  META_PAGE_ID               Facebook Page ID
#  META_IG_USER_ID            Instagram Business Account ID
#
#  ── Odoo ──
#  ODOO_URL                   http://localhost:8069
#  ODOO_DB                    Odoo database name
#  ODOO_USERNAME              Odoo admin username
#  ODOO_PASSWORD              Odoo admin password
#
#  ── Watcher Intervals (seconds) ──
#  WATCHER_GMAIL_INTERVAL     120
#  WATCHER_WHATSAPP_INTERVAL  60
#  WATCHER_LINKEDIN_INTERVAL  300
#  WATCHER_TWITTER_INTERVAL   180
#  WATCHER_INSTAGRAM_INTERVAL 300
#  WATCHER_ODOO_INTERVAL      600
#
#  ── Circuit Breaker ──
#  CIRCUIT_BREAKER_THRESHOLD  3   (failures before trip)
#  CIRCUIT_BREAKER_TIMEOUT    60  (seconds before recovery)
#
# ─────────────────────────────────────────────────────────────────────────
