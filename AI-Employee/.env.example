# ============================================
# AI Employee — Gold Tier Environment Variables
# ============================================
# Copy this file to .env and fill in your real credentials.
# NEVER commit the .env file to version control.
# ============================================

# --- Gmail Integration (SMTP — legacy fallback) ---
# Used by: ai_employee/integrations/gmail_client.py
# Get an App Password: Google Account > Security > 2-Step Verification > App Passwords
EMAIL_ADDRESS=you@gmail.com
EMAIL_PASSWORD=your-app-password

# --- Gmail API (OAuth2 — Advanced Gmail Agent) ---
# Used by: ai_employee/integrations/gmail_reader.py, gmail_sender.py
# Setup: Google Cloud Console > Enable Gmail API > Download credentials.json
# Docs: https://developers.google.com/gmail/api/quickstart/python
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# --- LinkedIn Integration ---
# Used by: ai_employee/integrations/linkedin_client.py, linkedin_scraper.py
LINKEDIN_EMAIL=you@email.com
LINKEDIN_PASSWORD=your-password

# --- LinkedIn Rate Limits (Anti-Spam Safety) ---
# Used by: ai_employee/agents/linkedin_agent.py
LINKEDIN_MAX_MSG_PER_HOUR=15
LINKEDIN_MAX_MSG_PER_DAY=80
LINKEDIN_MAX_CONN_PER_DAY=25

# --- Claude API (Task Intelligence Engine) ---
# Used by: ai_employee/brain/task_classifier.py, task_parser.py, task_priority_engine.py
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Gemini API (optional, for future AI-powered content generation) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Odoo Community (Self-Hosted Accounting) ---
# Used by: ai_employee/integrations/odoo_client.py, odoo_mcp_server.py
# Requires: Odoo 19+ running locally or on a server
ODOO_URL=http://localhost:8069
ODOO_DB=mycompany
ODOO_USERNAME=your-odoo-username
ODOO_PASSWORD=your-odoo-password

# --- Dashboard Settings ---
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080

# --- Operational Settings ---
CYCLE_INTERVAL=5
